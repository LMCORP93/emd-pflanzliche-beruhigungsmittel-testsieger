---
interface Article {
  title: string;
  excerpt: string;
  image: string;
  href: string;
  date?: string;
  readTime?: string;
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

<section class="articles-section">
  <div class="articles-container">
    <!-- Section heading -->
    <div class="articles-header">
      <h2 class="articles-heading">Dernières actualités</h2>
      <div class="articles-line"></div>
    </div>

    <!-- 3-column grid -->
    <div class="articles-grid">
      {articles.map((article) => (
        <a href={article.href} class="article-card">
          <!-- Image -->
          <div class="article-img-wrap">
            <img
              src={article.image}
              alt={article.title}
              class="article-img"
              loading="lazy"
            />
          </div>
          <!-- Content -->
          <div class="article-body">
            <h3 class="article-title">{article.title}</h3>
            <p class="article-excerpt">{article.excerpt}</p>
            <span class="article-read">
              Lire l'article
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .articles-section {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
    width: 100%;
  }
  @media (max-width: 767px) {
    .articles-section {
      padding-top: 2rem;
      padding-bottom: 2rem;
    }
  }

  .articles-container {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding-left: 0;
    padding-right: 0;
  }

  /* ── Header ── */
  .articles-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .articles-heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1.125rem, 1rem + 0.6vw, 1.375rem);
    color: #242424;
    margin: 0;
    white-space: nowrap;
    line-height: 1.3;
  }
  .articles-line {
    flex: 1;
    height: 1px;
    background: #e0e0e0;
  }

  /* ── Grid ── */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Card ── */
  .article-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  /* ── Image ── */
  .article-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f4f2ec;
  }
  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .article-card:hover .article-img {
    transform: scale(1.05);
  }

  /* ── Body ── */
  .article-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .article-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(0.875rem, 0.85rem + 0.15vw, 1rem);
    color: #242424;
    margin: 0;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .article-card:hover .article-title {
    color: #ef7a1a;
  }

  .article-excerpt {
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #777;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-read {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: clamp(0.75rem, 0.75rem + 0.1vw, 0.8125rem);
    color: #ef7a1a;
    margin-top: auto;
    padding-top: 0.5rem;
    transition: gap 0.2s;
  }
  .article-card:hover .article-read {
    gap: 0.625rem;
  }
</style>
