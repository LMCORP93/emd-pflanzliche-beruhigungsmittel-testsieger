---
interface Props {
  promoCode: string;
  promoPercent: number;
  ctaLink: string;
  heroImage: string;
}

const { promoCode, promoPercent, ctaLink, heroImage } = Astro.props;
---

<div id="newsletter-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Exklusives Angebot">
  <!-- Overlay -->
  <div id="modal-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Modal Content -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="relative bg-white rounded-xl shadow-modal max-w-[480px] w-full max-h-[90vh] overflow-y-auto">
      <!-- Close button -->
      <button
        id="modal-close"
        class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-bg-tertiary hover:bg-border-light transition-colors z-10 cursor-pointer border-0"
        aria-label="Schließen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#242424" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>

      <div class="p-6 md:p-8 text-center">
        <!-- Orange tag -->
        <div class="inline-block bg-primary text-white font-primary font-bold text-sm px-3 py-1 rounded-full mb-4">
          -{promoPercent}%
        </div>

        <!-- Heading -->
        <h3 class="font-primary font-bold text-xl md:text-2xl text-text-dark mb-2">
          Votre offre exclusive vous attend !
        </h3>
        <p class="text-text-grey text-sm mb-6 leading-relaxed">
          Utilisez ce code promo lors de votre commande et économisez {promoPercent}% immédiatement !
        </p>

        <!-- Promo code copy button -->
        <div class="mb-6">
          <button
            id="modal-copy-btn"
            class="copy-promo-btn inline-flex items-center gap-2 bg-bg-tertiary border border-border-light rounded px-4 py-2.5 text-sm font-mono font-semibold text-text-dark hover:bg-border-lighter transition-colors cursor-pointer"
            aria-label={`Copier le code promo ${promoCode}`}
            data-code={promoCode}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
            </svg>
            <span class="promo-code-text">{promoCode}</span>
            <span class="text-primary font-semibold">-{promoPercent}%</span>
          </button>
          <p id="modal-copy-feedback" class="copy-feedback">✓ Code copié !</p>
        </div>

        <!-- CTA Button -->
        <a
          href={ctaLink}
          rel="nofollow sponsored"
          target="_blank"
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-primary font-semibold text-base px-8 py-3 w-full mb-6 transition-colors no-underline"
          style="border-radius: 0.5rem;"
        >
          Profiter de l'offre
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>

        <!-- Hero Image -->
        <img src={heroImage} alt="Offer" class="w-48 h-48 mx-auto object-contain" loading="lazy" />
      </div>
    </div>
  </div>
</div>

<script>
  function initModal() {
    const modal = document.getElementById('newsletter-modal') as HTMLElement | null;
    const overlay = document.getElementById('modal-overlay');
    const closeBtn = document.getElementById('modal-close');
    const copyBtn = document.getElementById('modal-copy-btn') as HTMLElement | null;
    const feedback = document.getElementById('modal-copy-feedback');

    if (!modal) return;

    // Only once per session
    if (sessionStorage.getItem('emd-modal-shown')) return;

    // Show after 7s delay
    const timer = setTimeout(() => {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      sessionStorage.setItem('emd-modal-shown', 'true');
    }, 7000);

    // Close handlers
    const closeModal = () => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      clearTimeout(timer);
    };

    if (overlay) overlay.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);

    // Close on Escape key
    const escHandler = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
        document.removeEventListener('keydown', escHandler);
      }
    };
    document.addEventListener('keydown', escHandler);

    // Copy promo code to clipboard
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const code = copyBtn.getAttribute('data-code') || '';
        navigator.clipboard.writeText(code).then(() => {
          if (feedback) {
            feedback.classList.add('show');
            setTimeout(() => { feedback!.classList.remove('show'); }, 2000);
          }
        });
      });
    }
  }

  initModal();
</script>
