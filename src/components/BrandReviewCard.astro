---
import StarRating from './StarRating.astro';

interface Props {
  brandName: string;
  brandLogoSrc: string;
  rating: number;
  reviewLabel: string;
  ctaText: string;
  ctaLink: string;
}

const { brandName, brandLogoSrc, rating, reviewLabel, ctaText, ctaLink } = Astro.props;
---

<div class="brand-review-card">
  <!-- Logo -->
  <div class="brand-review-logo">
    <img
      src={brandLogoSrc}
      alt={`Logo ${brandName}`}
      class="brand-review-logo-img"
      loading="lazy"
    />
  </div>

  <!-- Review title -->
  <p class="brand-review-title">
    Unsere Bewertung für {brandName}
  </p>

  <!-- Star rating (orange star + score) -->
  <div class="brand-review-rating">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#ef7a1a" stroke="#ef7a1a" stroke-width="1" class="brand-review-star">
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
    </svg>
    <span class="brand-review-score">{rating.toFixed(1).replace('.', ',')}/10</span>
  </div>

  <!-- Review label -->
  <p class="brand-review-label">{reviewLabel}</p>

  <!-- CTA button -->
  <a
    href={ctaLink}
    rel="nofollow sponsored"
    target="_blank"
    class="brand-review-btn"
  >
    {ctaText}
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </a>
</div>

<style>
  .brand-review-card {
    background: #ffffff;
    border-radius: 1rem;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: fit-content;
  }

  .brand-review-logo {
    margin-bottom: 0.75rem;
  }
  .brand-review-logo-img {
    width: auto;
    height: 2rem;
    object-fit: contain;
    filter: brightness(0); /* Black */
  }

  .brand-review-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(0.8125rem, 0.8rem + 0.1vw, 0.875rem);
    color: #242424;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }

  .brand-review-rating {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.375rem;
  }
  .brand-review-star {
    flex-shrink: 0;
  }
  .brand-review-score {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
    color: #242424;
  }

  .brand-review-label {
    font-size: clamp(0.6875rem, 0.675rem + 0.1vw, 0.75rem);
    color: #777;
    margin: 0 0 1rem;
  }

  .brand-review-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    background-color: #ef7a1a;
    color: #fff;
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.75rem, 0.7rem + 0.25vw, 0.8125rem);
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s;
    cursor: pointer;
    border: none;
    width: 100%;
    white-space: nowrap;
  }
  .brand-review-btn:hover {
    background-color: #ff8c2e;
    color: #fff;
  }
  .brand-review-btn:active {
    background-color: #d66a12;
  }
</style>
