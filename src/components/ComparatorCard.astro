---
import StarRating from './StarRating.astro';
import PromoCodeButton from './PromoCodeButton.astro';

interface Product {
  rank: number;
  name: string;
  brand: string;
  slug: string;
  image: string;
  brandLogo: string;
  rating: number;
  reviewCount: number;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
  origin: string;
  availability: string;
  productType: string;
  pros: string[];
  cons: string[];
  description: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const rankEmoji = product.rank === 1 ? '🏆' : product.rank === 2 ? '🥈' : product.rank === 3 ? '🥉' : '';
const rankLabel = rankEmoji ? `${rankEmoji} TOP ${product.rank}` : `TOP ${product.rank}`;

const accordionId = `accordion-${product.slug}`;
const chevronId = `chevron-${product.slug}`;
---

<div class="cc-item">
  <div class="cc-card">

    <!-- ─── MAIN SECTION: Image + Content (horizontal) ─── -->
    <div class="cc-main">

      <!-- LEFT: Product image -->
      <div class="cc-img-col">
        <img
          src={product.image}
          alt={`${product.name} - ${product.brand}`}
          class="cc-img"
          loading="lazy"
        />
        <!-- Brand logo badge -->
        <div class="cc-badge-logo">
          <img src={product.brandLogo} alt={`Logo ${product.brand}`} class="cc-badge-img" loading="lazy" />
        </div>
        <!-- TOP badge -->
        {product.rank <= 3 && (
          <div class="cc-top-badge">
            <span>{rankLabel}</span>
          </div>
        )}
        {product.rank > 3 && (
          <div class="cc-top-badge is-plain">
            <span>TOP {product.rank}</span>
          </div>
        )}
      </div>

      <!-- RIGHT: Product info -->
      <div class="cc-content">
        <!-- Header: title + rating -->
        <div class="cc-header">
          <h3 class="cc-title">{product.name}</h3>
          <div class="cc-rating">
            <span class="cc-rating-val">{product.rating.toFixed(1)}</span>
            <span class="cc-rating-sep">/10</span>
            <svg class="cc-star-icon" viewBox="0 0 24 24" fill="#ef7a1a"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2L9.19 8.63L2 9.24l5.46 4.73L5.82 21z"/></svg>
          </div>
        </div>

        <!-- Trustpilot line -->
        <div class="cc-trust">
          <span>(</span>
          <span class="cc-trust-count">+{product.reviewCount.toLocaleString('de-DE')}</span>
          <span>Bewertungen</span>
          <svg class="cc-trust-logo" viewBox="0 0 24 24" fill="none">
            <path d="M17.56 21.56a1 1 0 0 1-.46-.11L12 18.22l-5.1 2.23a1 1 0 0 1-1.37-1.23l.98-5.59L3.29 9.7a1 1 0 0 1 .55-1.7l5.6-.81 2.5-5.08a1 1 0 0 1 1.8 0l2.5 5.08 5.6.81a1 1 0 0 1 .55 1.7l-3.07 2.99.98 5.59a1 1 0 0 1-.94 1.27z" fill="#00b67a"/>
          </svg>
          <span class="cc-trust-brand">Trustpilot</span>
          <span>)</span>
        </div>

        <!-- Info bullets -->
        <div class="cc-info">
          {product.promoCode && product.promoPercent > 0 && (
            <div class="cc-info-row">
              <svg class="cc-info-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              <span class="cc-info-label">Rabattcode:</span>
              <span class="cc-info-tag">-{product.promoPercent}%</span>
              <span class="cc-info-text">mit Code</span>
              <span class="cc-info-highlight">{product.promoCode}</span>
            </div>
          )}
          {product.origin && (
            <div class="cc-info-row">
              <svg class="cc-info-icon" viewBox="0 0 32 32" fill="currentColor"><path d="M16 2a14 14 0 1 0 14 14A14.016 14.016 0 0 0 16 2M4.02 16.394l1.338.446L7 19.303v1.283a1 1 0 0 0 .293.707L10 24v2.377a12 12 0 0 1-5.98-9.983M16 28a12 12 0 0 1-2.572-.285L14 26l1.805-4.512a1 1 0 0 0-.097-.926l-1.411-2.117a1 1 0 0 0-.832-.445h-4.93l-1.248-1.873L9.414 14H11v2h2v-2.734l3.868-6.77l-1.736-.992L14.277 7h-2.742L10.45 5.371A11.86 11.86 0 0 1 20 4.7V8a1 1 0 0 0 1 1h1.465a1 1 0 0 0 .832-.445l.877-1.316A12 12 0 0 1 26.894 11H22.82a1 1 0 0 0-.98.804l-.723 4.47a1 1 0 0 0 .54 1.055L25 19l.685 4.056A11.98 11.98 0 0 1 16 28"/></svg>
              <span class="cc-info-label">Herkunft:</span>
              <span class="cc-info-highlight">{product.origin}</span>
            </div>
          )}
          {product.availability && (
            <div class="cc-info-row">
              <svg class="cc-info-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2M1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1.003 1.003 0 0 0 20 4H5.21l-.94-2zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2"/></svg>
              <span class="cc-info-label">Verfügbarkeit:</span>
              <span class="cc-info-highlight">{product.availability}</span>
            </div>
          )}
        </div>

        <!-- Price -->
        <div class="cc-price">
          <span class="cc-price-old">{product.originalPrice}</span>
          <span class="cc-price-new">{product.discountPrice}</span>
        </div>

        <!-- Buttons row -->
        <div class="cc-btns">
          {product.promoCode && product.promoPercent > 0 && (
            <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
          )}
          <a
            href={product.affiliateLink}
            rel="nofollow sponsored"
            target="_blank"
            class="btn-solid cc-cta"
          >
            <span>Ansehen</span>
            <span class="cc-cta-brand">{product.brand}</span>
            <svg class="cc-cta-arrow" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16M6.75 9.25a.75.75 0 0 0 0 1.5h4.59l-2.1 1.95a.75.75 0 0 0 1.02 1.1l3.5-3.25a.75.75 0 0 0 0-1.1l-3.5-3.25a.75.75 0 1 0-1.02 1.1l2.1 1.95z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── ACCORDION: Mehr erfahren ─── -->
    <div class="cc-accordion-section">
      <button
        class="cc-accordion-trigger"
        data-target={accordionId}
        data-chevron={chevronId}
        aria-expanded="false"
        aria-controls={accordionId}
      >
        <span class="cc-accordion-label">Mehr zur Marke erfahren</span>
        <svg
          id={chevronId}
          class="cc-accordion-chevron"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#777"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </button>

      <div id={accordionId} class="cc-accordion-content">
        <!-- Description rich text -->
        <div class="cc-accordion-text">
          <p>{product.description}</p>
        </div>

        <!-- Pros / Cons 2-col grid -->
        <div class="cc-proscons">
          <!-- Stärken -->
          <div class="cc-proscons-col cc-col-green">
            <div class="cc-proscons-header">
              <svg class="cc-proscons-icon" viewBox="0 0 256 256" fill="currentColor"><path d="M246 80a26 26 0 1 0-46.6 15.84l-29.83 36.72-26-59.76a26 26 0 1 0-31.16 0l-26 59.76L56.6 95.84a26 26 0 1 0-22.36 10.09L49 194.3A14 14 0 0 0 62.78 206h130.44A14 14 0 0 0 207 194.3l14.73-88.37A26 26 0 0 0 246 80M128 38a14 14 0 1 1-14 14 14 14 0 0 1 14-14M22 80a14 14 0 1 1 14 14 14 14 0 0 1-14-14m173.2 112.33a2 2 0 0 1-2 1.67H62.78a2 2 0 0 1-2-1.67L46.08 104l1.22-.55 36 44.36A6 6 0 0 0 88 150a5.5 5.5 0 0 0 .81-.06 6 6 0 0 0 4.69-3.55l29.92-68.8a25.8 25.8 0 0 0 9.16 0l29.92 68.8a6 6 0 0 0 4.69 3.55 5.5 5.5 0 0 0 .81.06 6 6 0 0 0 4.66-2.22l36-44.36 1.22.55ZM220 94a14 14 0 1 1 14-14 14 14 0 0 1-14 14"/></svg>
              <span>Stärken</span>
            </div>
            <ul>
              {product.pros.map((pro) => (
                <li>{pro}</li>
              ))}
            </ul>
          </div>

          <!-- Zu beachten -->
          <div class="cc-proscons-col cc-col-orange">
            <div class="cc-proscons-header">
              <svg class="cc-proscons-icon" viewBox="0 0 32 32" fill="currentColor"><path d="M16 23a1.5 1.5 0 1 0 1.5 1.5A1.5 1.5 0 0 0 16 23m-1-11h2v9h-2z"/><path d="M29 30H3a1 1 0 0 1-.887-1.461l13-25a1 1 0 0 1 1.774 0l13 25A1 1 0 0 1 29 30M4.65 28h22.7l.001-.003L16.002 6.17h-.004L4.648 27.997Z"/></svg>
              <span>Zu beachten</span>
            </div>
            <ul>
              {product.cons.map((con) => (
                <li>{con}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── FOOTER CTA ─── -->
    <div class="cc-footer">
      <a
        href={product.affiliateLink}
        rel="nofollow sponsored"
        target="_blank"
        class="btn-solid cc-footer-btn"
      >
        <span>Ansehen</span>
        <span class="cc-cta-brand">{product.brand}</span>
        <svg class="cc-cta-arrow" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16M6.75 9.25a.75.75 0 0 0 0 1.5h4.59l-2.1 1.95a.75.75 0 0 0 1.02 1.1l3.5-3.25a.75.75 0 0 0 0-1.1l-3.5-3.25a.75.75 0 1 0-1.02 1.1l2.1 1.95z" clip-rule="evenodd"/></svg>
      </a>
    </div>

  </div>
</div>

<script>
  function initComparatorAccordions() {
    document.querySelectorAll('.cc-accordion-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        const chevronId = trigger.getAttribute('data-chevron');
        if (!targetId) return;

        const content = document.getElementById(targetId);
        if (!content) return;

        const isHidden = content.classList.contains('cc-hidden');
        content.classList.toggle('cc-hidden');

        if (chevronId) {
          const chevron = document.getElementById(chevronId);
          if (chevron) {
            chevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
          }
        }

        trigger.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      });
    });
  }

  initComparatorAccordions();
  document.addEventListener('astro:page-load', initComparatorAccordions);
</script>

<style>
  /* ── Card shell ── */
  .cc-card {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #e0e0e0;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.2s;
  }
  .cc-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);
  }

  /* ── Main section: horizontal on desktop ── */
  .cc-main {
    display: flex;
    flex-direction: column;
  }
  @media (min-width: 768px) {
    .cc-main {
      flex-direction: row;
    }
    .cc-main .cc-img-col {
      flex: 1;
    }
    .cc-main .cc-content {
      flex: 2;
    }
  }

  /* ── Image column ── */
  .cc-img-col {
    position: relative;
    background: linear-gradient(135deg, #f4f2ec 0%, #ede5d8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .cc-img-col {
      width: 1fr;
      min-width: 0;
      padding: 0;
      min-height: 100%;
    }
  }
  @media (max-width: 767px) {
    .cc-img-col {
      max-height: 220px;
    }
  }

  .cc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Brand logo badge - bottom right */
  .cc-badge-logo {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: #ffffff;
    border-radius: 0.5rem;
    padding: 0.5rem;
    min-width: 5.5rem;
    min-height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
    z-index: 2;
  }
  .cc-badge-img {
    width: auto;
    height: auto;
    max-width: 5.25rem;
    max-height: 2.25rem;
    object-fit: contain;
    display: block;
  }

  /* TOP badge - top left */
  .cc-top-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #ffffff;
    color: #111111;
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: clamp(0.6875rem, 0.675rem + 0.1vw, 0.75rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(239, 122, 26, 0.18);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
    z-index: 3;
  }
  .cc-top-badge.is-plain {
    color: #555;
    border-color: rgba(0, 0, 0, 0.08);
  }

  /* ── Content column ── */
  .cc-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }
  @media (max-width: 767px) {
    .cc-content {
      padding: 1.25rem;
    }
  }

  /* Header: title + rating */
  .cc-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .cc-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(0.9375rem, 0.9rem + 0.2vw, 1.125rem);
    color: #111;
    margin: 0;
    line-height: 1.3;
  }
  .cc-rating {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    flex-shrink: 0;
  }
  .cc-rating-val {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: #111;
  }
  .cc-rating-sep {
    font-size: 0.8125rem;
    color: #777;
  }
  .cc-star-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-left: 0.25rem;
  }

  /* Trustpilot line */
  .cc-trust {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: #777;
  }
  .cc-trust-count {
    font-weight: 600;
    color: #555;
  }
  .cc-trust-logo {
    width: 14px;
    height: 14px;
  }
  .cc-trust-brand {
    font-size: 0.75rem;
    color: #00b67a;
    font-weight: 600;
  }

  /* ── Info bullets ── */
  .cc-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cc-info-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.4;
  }
  .cc-info-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: #777;
  }
  .cc-info-label {
    color: #777;
  }
  .cc-info-tag {
    background: rgba(239, 122, 26, 0.08);
    border: 1px solid rgba(239, 122, 26, 0.2);
    color: #ef7a1a;
    font-weight: 600;
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 6px;
  }
  .cc-info-text {
    color: #777;
  }
  .cc-info-highlight {
    font-weight: 600;
    color: #ef7a1a;
  }

  /* ── Price ── */
  .cc-price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .cc-price-old {
    font-size: 0.875rem;
    color: #999;
    text-decoration: line-through;
  }
  .cc-price-new {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.5rem);
    color: #242424;
    line-height: 1;
  }

  /* ── Buttons row ── */
  .cc-btns {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  @media (max-width: 767px) {
    .cc-btns {
      flex-direction: column;
      align-items: stretch;
    }
    .cc-btns .btn-solid,
    .cc-btns .btn-dashed {
      width: 100%;
      justify-content: center;
    }
  }

  .cc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: #ef7a1a;
    color: #ffffff !important;
    border: none;
  }
  .cc-cta:hover {
    background: #ff8c2e;
    color: #ffffff !important;
  }
  .cc-cta-brand {
    font-weight: 400;
    color: #ffffff !important;
  }
  .cc-cta-arrow {
    width: 16px;
    height: 16px;
  }

  /* ── Accordion ── */
  .cc-accordion-section {
    border-top: 1px solid #e8e8e8;
    padding: 0 1.5rem;
  }
  @media (max-width: 767px) {
    .cc-accordion-section {
      padding: 0 1.25rem;
    }
  }

  .cc-accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 0;
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
  }
  .cc-accordion-label {
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: 0.8125rem;
    color: #333;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cc-accordion-trigger:hover .cc-accordion-label {
    color: #ef7a1a;
  }
  .cc-accordion-chevron {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .cc-accordion-content {
    padding-bottom: 1.25rem;
    transition: all 0.3s ease;
  }
  .cc-accordion-content.cc-hidden {
    display: none;
  }
  .cc-accordion-content:not(.cc-hidden) {
    animation: ccSlideOpen 0.3s ease-out;
  }

  @keyframes ccSlideOpen {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cc-accordion-text {
    margin-bottom: 1rem;
  }
  .cc-accordion-text p {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Pros / Cons grid ── */
  .cc-proscons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  @media (max-width: 479px) {
    .cc-proscons {
      grid-template-columns: 1fr;
    }
  }

  .cc-proscons-col {
    border-radius: 8px;
    padding: 1rem;
  }
  .cc-col-green {
    background: #cef5ca;
  }
  .cc-col-orange {
    background: #fcf8d8;
  }

  .cc-proscons-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }
  .cc-proscons-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .cc-col-green .cc-proscons-icon { color: #114e0b; }
  .cc-col-green .cc-proscons-header span { color: #114e0b; }
  .cc-col-orange .cc-proscons-icon { color: #5e5515; }
  .cc-col-orange .cc-proscons-header span { color: #5e5515; }

  .cc-proscons-header span {
    font-family: 'Archivo', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .cc-proscons-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .cc-col-green ul li {
    color: #114e0b;
  }
  .cc-col-orange ul li {
    color: #5e5515;
  }
  .cc-proscons-col ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.375rem;
    font-size: 0.8125rem;
    line-height: 1.5;
  }
  .cc-col-green ul li::before {
    content: '✓';
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cc-col-orange ul li::before {
    content: '⚠';
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── Footer CTA ── */
  .cc-footer {
    border-top: 1px solid #e8e8e8;
