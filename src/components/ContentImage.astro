---
/**
 * ContentImage - Image generated by Fal.ai, displayed inline in article content.
 * 
 * Usage:
 *   <ContentImage 
 *     src="/images/content/hero-banner.webp" 
 *     alt="Description SEO de l'image"
 *     caption="Légende optionnelle sous l'image"
 *   />
 */
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="content-image">
  <img src={src} alt={alt} loading="lazy" decoding="async" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .content-image {
    margin: 1.5rem 0;
    border-radius: 12px;
    overflow: hidden;
  }
  .content-image img {
    width: 100%;
    display: block;
    object-fit: cover;
    max-height: 400px;
  }
  .content-image figcaption {
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    color: #777;
    text-align: center;
    background-color: #f9f9f9;
    font-style: italic;
  }
  @media (max-width: 767px) {
    .content-image img {
      max-height: 240px;
    }
  }
</style>
