---
interface Props {
  rating: number;
  size?: 'sm' | 'md' | 'lg';
  showText?: boolean;
}

const { rating, size = 'md', showText = false } = Astro.props;

const sizeClasses = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const textClasses = {
  sm: 'text-xs',
  md: 'text-sm',
  lg: 'text-base',
};
---

<div class="inline-flex items-center gap-1">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#ef7a1a"
    stroke="#ef7a1a"
    stroke-width="1"
    class={sizeClasses[size]}
  >
    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
  </svg>
  {showText && (
    <span class={`font-primary font-bold text-text-dark ${textClasses[size]}`}>
      {rating.toFixed(1)}/10
    </span>
  )}
</div>
