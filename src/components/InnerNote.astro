---
interface Props {
  text: string;
  emoji?: string;
  variant?: 'default' | 'transparent';
}

const { text, emoji = '📌', variant = 'default' } = Astro.props;
---

<div class:list={[
  'flex flex-col justify-start items-start gap-4 p-6 rounded-card',
  variant === 'transparent'
    ? 'bg-transparent pt-0 pb-0'
    : 'bg-grey-bg',
]}>
  <p class="m-0 text-[0.9375rem] leading-[1.625] text-[#2d2d2d]">
    <span class="mr-2">{emoji}</span>
    <Fragment set:html={text} />
  </p>
</div>
