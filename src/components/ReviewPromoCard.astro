---
import StarRating from './StarRating.astro';
import PromoCodeButton from './PromoCodeButton.astro';

interface Product {
  name: string;
  image: string;
  rating: number;
  productType: string;
  productCategory: string;
  origin: string;
  availability: string;
  shipping?: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  affiliateLink: string;
  originFlag?: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const cleanOrigin = product.origin.replace(/^[\u{1F1E6}-\u{1F1FF}]{2}\s*/u, '');
const originPrefix = product.originFlag || (/^[\u{1F1E6}-\u{1F1FF}]{2}/u.test(product.origin) ? '' : '🇫🇷');
---

<div class="rpc-card">
  <!-- LEFT: Product image - full bleed -->
  <div class="rpc-img-col">
    <img
      src={product.image}
      alt={product.name}
      class="rpc-img"
      loading="lazy"
    />
  </div>

  <!-- RIGHT: Product details -->
  <div class="rpc-content">

    <!-- Header: title + rating -->
    <div class="rpc-header">
      <h4 class="rpc-title">{product.name}</h4>
      <div class="rpc-rating">
        <StarRating rating={product.rating} size="sm" />
        <span class="rpc-rating-val">{product.rating.toFixed(1)}</span>
        <span class="rpc-rating-sep">/10</span>
      </div>
    </div>

    <!-- Info rows -->
    <div class="rpc-info">
      <!-- Type de complément -->
      <div class="rpc-info-row">
        <svg class="rpc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c-4.97 0-9 3.13-9 7s4.03 7 9 7 9-3.13 9-7-4.03-7-9-7z"/><path d="M12 3c-1.66 0-3 1.12-3 2.5S10.34 8 12 8s3-1.12 3-2.5S13.66 3 12 3z"/><path d="M9 17v2a3 3 0 0 0 6 0v-2"/><path d="M12 17v5"/></svg>
        <span class="rpc-label">Format:</span>
        <span class="rpc-value">{product.productCategory || product.productType}</span>
      </div>
      <!-- Origine -->
      <div class="rpc-info-row">
        <svg class="rpc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        <span class="rpc-label">Herkunft:</span>
        <span class="rpc-value">{originPrefix} {cleanOrigin}</span>
      </div>
      <!-- Lieferung -->
      <div class="rpc-info-row">
        <svg class="rpc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
        <span class="rpc-label">Lieferung:</span>
        <span class="rpc-value">{product.shipping || 'Online verfügbar'}</span>
      </div>
      <!-- Promo -->
      {product.promoCode && product.promoPercent > 0 && (
        <div class="rpc-info-row">
          <svg class="rpc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          <span class="rpc-label">-{product.promoPercent}%</span>
          <span class="rpc-label rpc-label-light">mit dem Code:</span>
          <span class="rpc-value">{product.promoCode}</span>
        </div>
      )}
    </div>

    <!-- Price -->
    <div class="rpc-price">
      <span class="rpc-price-label">Ab:</span>
      <span class="rpc-price-old">{product.originalPrice}</span>
      <span class="rpc-price-new">{product.discountPrice}</span>
    </div>

    <!-- Actions -->
    <div class="rpc-actions">
      {product.promoCode && product.promoPercent > 0 && (
        <PromoCodeButton code={product.promoCode} percent={`${product.promoPercent}%`} />
      )}
      <a
        href={product.affiliateLink}
        rel="nofollow sponsored"
        target="_blank"
        class="btn-solid rpc-cta"
      >
        <span>Jetzt ansehen</span>
        <span class="rpc-cta-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>
    </div>

    <!-- Verified badge -->
    <p class="rpc-verified">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect width="14" height="14" rx="3" fill="#00b67a"/>
        <path d="M4 7L6.5 9.5L10 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Code geprüft und gültig für 2026
    </p>
  </div>
</div>

<style>
  /* ── Card shell ── */
  .rpc-card {
    display: grid;
    grid-template-columns: 0.55fr 1fr;
    border-radius: 12px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    margin-bottom: 2rem;
    width: 100%;
  }

  @media (max-width: 767px) {
    .rpc-card {
      grid-template-columns: 1fr;
      row-gap: 1rem;
    }
    .rpc-img-col {
      max-height: 12rem;
    }
  }

  /* ── Left: image - full bleed, compact ── */
  .rpc-img-col {
    background: linear-gradient(135deg, #f4f2ec 0%, #ede5d8 100%);
    overflow: hidden;
  }

  .rpc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Right: content ── */
  .rpc-content {
    padding: 1.75rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 767px) {
    .rpc-content {
      padding: 1.25rem;
      gap: 0.875rem;
    }
  }

  /* ── Header ── */
  .rpc-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .rpc-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.25rem);
    color: #111;
    margin: 0;
    line-height: 1.3;
  }

  .rpc-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .rpc-rating-val {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: #111;
  }

  .rpc-rating-sep {
    font-family: 'Archivo', sans-serif;
    font-weight: 400;
    font-size: 0.8125rem;
    color: #777;
  }

  /* ── Info rows ── */
  .rpc-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rpc-info-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.4;
  }

  .rpc-label {
    color: #555;
  }

  .rpc-label-light {
    color: #777;
  }

  .rpc-value {
    font-weight: 600;
    color: #111;
  }

  .rpc-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #333;
  }

  /* ── Price ── */
  .rpc-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rpc-price-label {
    font-size: 0.875rem;
    color: #999;
  }

  .rpc-price-old {
    font-size: 0.875rem;
    color: #999;
    text-decoration: line-through;
  }

  .rpc-price-new {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: clamp(1.25rem, 1.1rem + 0.75vw, 1.75rem);
    color: #ef7a1a;
    line-height: 1;
  }

  /* ── Actions ── */
  .rpc-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  @media (max-width: 767px) {
    .rpc-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .rpc-actions .btn-solid,
    .rpc-actions .btn-dashed {
      width: 100%;
      justify-content: center;
    }
  }

  /* ── Verified ── */
  .rpc-verified {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #111;
    font-weight: 700;
    margin: 0;
  }
</style>
