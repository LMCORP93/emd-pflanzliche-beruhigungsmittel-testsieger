---
interface Props {
  logoSrc: string;
  promoCode: string;
  promoPercent: number;
  originalPrice: string;
  discountPrice: string;
  ctaLink: string;
  heroImage: string;
  rating: number;
  reviewCount: number;
  productName?: string;
  brandName?: string;
}

const { logoSrc, promoCode, promoPercent, originalPrice, discountPrice, ctaLink, heroImage, rating, reviewCount, productName, brandName } = Astro.props;
---

<div class="cta_component flex flex-col gap-4 rounded-card text-center bg-white p-4 shadow-cta-card">
  <!-- Product image at top -->
  <div class="rounded-xl overflow-hidden bg-grey-bg">
    <img
      src={heroImage}
      alt={productName ? `${productName} - empfohlenes Produkt` : 'Empfohlenes Produkt'}
      loading="lazy"
      class="w-full h-auto object-cover block"
    />
  </div>

  <!-- Star rating (orange stars) -->
  <div class="flex justify-center items-center gap-0.5">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill={i < Math.round(rating) ? '#ef7a1a' : '#e0e0e0'}
        stroke={i < Math.round(rating) ? '#ef7a1a' : '#e0e0e0'}
        stroke-width="0.5"
        class="star w-[1.1rem] h-[1.1rem]"
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
      </svg>
    ))}
  </div>
  <p class="text-[0.8125rem] text-[#333] m-0 -mt-2">{reviewCount.toLocaleString('de-DE')} geprüfte Bewertungen</p>

  <!-- Promo code badge with orange background -->
  <div class="flex justify-center">
    <span class="review_tag bg-orange text-[#f2f2f2] rounded-button py-1 px-2 font-semibold text-sm">
      Code: {promoCode} → -{promoPercent}%
    </span>
  </div>

  <!-- Price: original (strikethrough) + discount (orange, bold) -->
  <div class="flex items-baseline justify-center gap-3">
    <span class="compare-at-price-text text-text-muted line-through text-sm">{originalPrice}</span>
    <span class="text-orange font-bold text-2xl leading-none">{discountPrice}</span>
  </div>

  <!-- Großer orangefarbener Angebotsbutton (rounded pill) -->
  <a
    href={ctaLink}
    rel="nofollow sponsored"
    target="_blank"
    class="flex items-center justify-center gap-2 bg-orange text-white font-primary text-sm font-semibold py-2 px-4 rounded-button no-underline transition-colors duration-200 cursor-pointer border-none w-full hover:bg-[#ff8c2e] hover:text-white active:bg-[#d66a12] whitespace-nowrap"
  >
    Angebot ansehen
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </a>

  <!-- Verification badge at bottom (green checkmark + text) -->
  <div class="verified-badge">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00b67a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="verified-icon">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
      <polyline points="22 4 12 14.01 9 11.01" />
    </svg>
    <span class="verified-text">Code geprüft und gültig für 2026</span>
  </div>
</div>

<style>
  /* ── Verified badge (icon + text on one line) ──── */
  .verified-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    white-space: nowrap;
  }
  .verified-icon {
    flex-shrink: 0;
  }
  .verified-text {
    font-size: 0.75rem;
    color: #00b67a;
  }

  /* ── Sticky card on desktop ─────────────────────── */
  @media (min-width: 992px) {
    .cta_component {
      position: sticky;
      top: 5rem;
    }
  }
</style>
