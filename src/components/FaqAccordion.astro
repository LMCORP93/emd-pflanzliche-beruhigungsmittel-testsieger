---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="flex flex-col gap-3 w-full">
  {items.map((item, i) => (
    <div class="accordion-item border border-border-color rounded-card bg-white p-4">
      <button
        class="accordion-item-trigger cursor-pointer flex justify-between items-start w-full text-left gap-4 bg-transparent border-none p-0"
        data-target={`faq-answer-${i}`}
        aria-expanded="false"
        aria-controls={`faq-answer-${i}`}
      >
        <span class="font-primary font-semibold text-[clamp(0.8125rem,0.8rem+0.1vw,0.875rem)] text-[#242424] leading-[1.4]">
          {item.question}
        </span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#777"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="accordion-chevron flex-shrink-0 transition-transform duration-300 ease-in-out"
          aria-hidden="true"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </button>
      <div
        id={`faq-answer-${i}`}
        class="accordion-item-content overflow-hidden transition-all duration-300 ease-in-out"
        role="region"
        style="max-height: 0; opacity: 0;"
      >
        <div class="pt-3 text-[clamp(0.8125rem,0.8rem+0.1vw,0.875rem)] text-[#333] leading-[1.6]">
          <p class="m-0">{item.answer}</p>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  function initFaq() {
    const triggers = document.querySelectorAll('.accordion-item-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        if (!targetId) return;

        const target = document.getElementById(targetId);
        if (!target) return;

        const isOpen = target.style.maxHeight && target.style.maxHeight !== '0px';

        // Close all others
        document.querySelectorAll('.accordion-item-content').forEach((content) => {
          (content as HTMLElement).style.maxHeight = '0px';
          (content as HTMLElement).style.opacity = '0';
        });
        document.querySelectorAll('.accordion-chevron').forEach((chevron) => {
          (chevron as SVGElement).style.transform = 'rotate(0deg)';
        });
        document.querySelectorAll('.accordion-item-trigger').forEach((t) => {
          t.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
          target.style.maxHeight = target.scrollHeight + 'px';
          target.style.opacity = '1';
          const chevron = trigger.querySelector('.accordion-chevron');
          if (chevron) {
            (chevron as SVGElement).style.transform = 'rotate(180deg)';
          }
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaq();
</script>
