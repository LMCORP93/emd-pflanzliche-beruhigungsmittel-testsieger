---
import config from '@/data/site.config';

const homeUrl = config.domain;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={homeUrl} />
    <title>Seite nicht gefunden | {config.siteName}</title>
    <style>
      :root {
        font-family: Archivo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #15221a;
        background: #faf4e8;
      }
      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        padding: 24px;
      }
      main {
        max-width: 640px;
        padding: 40px;
        border: 1px solid rgba(21, 34, 26, 0.14);
        border-radius: 28px;
        background: #fffaf0;
        box-shadow: 0 24px 80px rgba(21, 34, 26, 0.08);
        text-align: center;
      }
      p {
        color: #526257;
        line-height: 1.65;
      }
      a {
        display: inline-flex;
        margin-top: 18px;
        padding: 14px 22px;
        border-radius: 999px;
        background: #1f6b45;
        color: white;
        text-decoration: none;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <p>Erreur 404</p>
      <h1>Seite nicht gefunden</h1>
      <p>Diese URL existiert nicht oder enthält einen Tippfehler. Zurück zum Vergleich der pflanzlichen Beruhigungsmittel.</p>
      <a href="/">Zurück zum Vergleich</a>
    </main>
  </body>
</html>
